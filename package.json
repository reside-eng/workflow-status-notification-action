{
  "name": "@side/workflow-status-notification-action",
  "version": "0.0.0-development",
  "description": "Github Action workflow failure/success notification.",
  "type": "module",
  "main": "dist/index.mjs",
  "engines": {
    "node": "^24.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "lefthook install",
    "build:docs": "tsx bin/generate-docs.ts",
    "build": "rimraf dist && node build.mjs && yarn build:docs",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --write --error-on-warnings",
    "check:fix:staged": "biome check --write --error-on-warnings --staged --no-errors-on-unmatched",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "format": "biome format --write --error-on-warnings",
    "format:check": "biome format --error-on-warnings",
    "types:check": "tsc --noEmit",
    "test": "yarn types:check && GITHUB_REPOSITORY='reside-eng/workflow-status-notification-action' vitest run",
    "test:cov": "yarn types:check && GITHUB_REPOSITORY='reside-eng/workflow-status-notification-action' vitest run --coverage"
  },
  "dependencies": {
    "@actions/cache": "6.0.0",
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "ky": "2.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.1",
    "@side/commitlint-config": "1.1.1",
    "@tsconfig/node24": "24.0.4",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "esbuild": "0.28.0",
    "js-yaml": "4.1.1",
    "lefthook": "2.1.6",
    "rimraf": "6.1.3",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reside-eng/workflow-status-notification-action"
  },
  "keywords": [
    "actions",
    "workflow",
    "slack notification"
  ],
  "author": "Side",
  "license": "MIT",
  "packageManager": "yarn@4.15.0",
  "private": true
}
