{
  "name": "@side/workflow-status-notification-action",
  "version": "0.0.0-development",
  "description": "Github Action workflow failure/success notification.",
  "main": "dist/index.js",
  "engines": {
    "node": "^24.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "build:docs": "tsx bin/generate-docs.ts",
    "build": "rimraf dist && ncc build src/index.ts && yarn build:docs",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --write --error-on-warnings",
    "check:fix:staged": "biome check --write --error-on-warnings --staged --no-errors-on-unmatched",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "format": "biome format --write --error-on-warnings",
    "format:check": "biome format --error-on-warnings",
    "types:check": "tsc --noEmit",
    "test": "yarn types:check && GITHUB_REPOSITORY='reside-eng/workflow-status-notification-action' jest"
  },
  "dependencies": {
    "@actions/cache": "6.0.0",
    "@actions/core": "2.0.3",
    "@actions/exec": "1.1.1",
    "@actions/github": "7.0.0",
    "got": "11.8.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "20.5.3",
    "@side/commitlint-config": "1.1.1",
    "@swc/core": "1.15.33",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.2",
    "@vercel/ncc": "0.38.4",
    "jest": "30.3.0",
    "js-yaml": "4.1.1",
    "lefthook": "2.1.6",
    "nock": "14.0.14",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reside-eng/workflow-status-notification-action"
  },
  "keywords": [
    "actions",
    "workflow",
    "slack notification"
  ],
  "author": "Side",
  "license": "MIT",
  "packageManager": "yarn@4.14.1",
  "private": true
}
